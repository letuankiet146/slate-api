# Copy to .env and adjust values before running docker compose or deploying.
# Never commit .env to version control.

# PostgreSQL (docker compose postgres service)
POSTGRES_DB=slatevn
POSTGRES_USER=slatevn
POSTGRES_PASSWORD=change-me

# API database connection
DATABASE_URL=jdbc:postgresql://postgres:5432/slatevn
DATABASE_USERNAME=slatevn
DATABASE_PASSWORD=change-me

# JWT signing secret (use a long random value in production)
JWT_SECRET=change-me-to-a-very-long-secret-key-at-least-256-bits
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=14

# Bootstrap admin user (created on first API startup only)
ADMIN_EMAIL=admin@slatevn.local
ADMIN_PASSWORD=change-me
ADMIN_DISPLAY_NAME=System Admin

# Comma-separated frontend origins allowed by CORS (required when frontend is hosted separately)
# Examples:
#   Local dev:  http://localhost:5173,http://localhost:3000
#   Production: https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
